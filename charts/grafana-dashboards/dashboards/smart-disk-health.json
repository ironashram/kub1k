{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "noValue": "-",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Temp" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 45 },
                    { "color": "red", "value": 60 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Spare %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 10 },
                    { "color": "green", "value": 50 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Wear %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 50 },
                    { "color": "red", "value": 80 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Media Errors" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 1000 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Critical" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "showHeader": true,
        "sortBy": [
          { "displayName": "Spare %", "desc": true },
          { "displayName": "Instance", "desc": false }
        ]
      },
      "title": "Disk Health",
      "type": "table",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "^(instance 1|disk 1|model 1|serial 1|Value #(Temp|Spare|Used|Errors|Crit))$"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance 1": "Instance",
              "disk 1": "Disk",
              "model 1": "Model",
              "serial 1": "Serial",
              "Value #Temp": "Temp",
              "Value #Spare": "Spare %",
              "Value #Used": "Wear %",
              "Value #Errors": "Media Errors",
              "Value #Crit": "Critical"
            },
            "indexByName": {
              "instance 1": 0,
              "disk 1": 1,
              "model 1": 2,
              "serial 1": 3,
              "Value #Temp": 4,
              "Value #Spare": 5,
              "Value #Used": 6,
              "Value #Errors": 7,
              "Value #Crit": 8
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(smartmon_temperature_celsius{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"disk\")",
          "refId": "Temp",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(smartmon_available_spare{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"disk\")",
          "refId": "Spare",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(smartmon_percentage_used{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"disk\")",
          "refId": "Used",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(smartmon_media_errors{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"disk\")",
          "refId": "Errors",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(smartmon_critical_warning{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"disk\")",
          "refId": "Crit",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "h",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 13 },
      "id": 8,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "title": "Power On Hours (per disk, sorted)",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_power_on_hours_total{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} / {{disk}}",
          "refId": "A",
          "instant": true,
          "format": "time_series"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": { "regex": ".*\\{instance=\"([^\"]+)\", disk=\"([^\"]+)\".*", "renamePattern": "$1 / $2" }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 3,
      "title": "Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 4,
      "title": "Temperature Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_temperature_celsius{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} / {{disk}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 5,
      "title": "SMART Errors Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_media_errors{instance=~\"$instance\"}",
          "legendFormat": "media / {{instance}} / {{disk}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_num_err_log_entries{instance=~\"$instance\"}",
          "legendFormat": "log / {{instance}} / {{disk}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_critical_warning{instance=~\"$instance\"}",
          "legendFormat": "crit / {{instance}} / {{disk}}",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 6,
      "title": "Data Read Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(smartmon_data_units_read{instance=~\"$instance\"}[5m]) * 512000",
          "legendFormat": "{{instance}} / {{disk}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 7,
      "title": "Data Write Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(smartmon_data_units_written{instance=~\"$instance\"}[5m]) * 512000",
          "legendFormat": "{{instance}} / {{disk}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(smartmon_temperature_celsius, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "name": "instance",
        "options": [],
        "query": {
          "query": "label_values(smartmon_temperature_celsius, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "browser",
  "title": "SMART Disk Health",
  "uid": "smart-disk-health",
  "version": 1
}
