{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Temp" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 45 },
                    { "color": "red", "value": 60 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Spare %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 10 },
                    { "color": "green", "value": 50 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Wear %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 50 },
                    { "color": "red", "value": 80 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Power On Hours" },
            "properties": [{ "id": "unit", "value": "h" }]
          },
          {
            "matcher": { "id": "byName", "options": "Media Errors" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Critical" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Instance", "desc": false }]
      },
      "title": "Disk Health",
      "type": "table",
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "valueLabel": "__name__" }
        },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "instance": { "operation": "groupby" },
              "disk": { "operation": "groupby" },
              "model": { "operation": "aggregate", "aggregations": ["lastNotNull"] },
              "serial": { "operation": "aggregate", "aggregations": ["lastNotNull"] },
              "smartmon_temperature_celsius": { "operation": "aggregate", "aggregations": ["lastNotNull"] },
              "smartmon_available_spare": { "operation": "aggregate", "aggregations": ["lastNotNull"] },
              "smartmon_percentage_used": { "operation": "aggregate", "aggregations": ["lastNotNull"] },
              "smartmon_power_on_hours_total": { "operation": "aggregate", "aggregations": ["lastNotNull"] },
              "smartmon_media_errors": { "operation": "aggregate", "aggregations": ["lastNotNull"] },
              "smartmon_critical_warning": { "operation": "aggregate", "aggregations": ["lastNotNull"] }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "Instance",
              "disk": "Disk",
              "model (lastNotNull)": "Model",
              "serial (lastNotNull)": "Serial",
              "smartmon_temperature_celsius (lastNotNull)": "Temp",
              "smartmon_available_spare (lastNotNull)": "Spare %",
              "smartmon_percentage_used (lastNotNull)": "Wear %",
              "smartmon_power_on_hours_total (lastNotNull)": "Power On Hours",
              "smartmon_media_errors (lastNotNull)": "Media Errors",
              "smartmon_critical_warning (lastNotNull)": "Critical"
            },
            "indexByName": {
              "instance": 0,
              "disk": 1,
              "model (lastNotNull)": 2,
              "serial (lastNotNull)": 3,
              "smartmon_temperature_celsius (lastNotNull)": 4,
              "smartmon_available_spare (lastNotNull)": 5,
              "smartmon_percentage_used (lastNotNull)": 6,
              "smartmon_power_on_hours_total (lastNotNull)": 7,
              "smartmon_media_errors (lastNotNull)": 8,
              "smartmon_critical_warning (lastNotNull)": 9
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "{__name__=~\"smartmon_.*\", instance=~\"$instance\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 3,
      "title": "Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 4,
      "title": "Temperature Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_temperature_celsius{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} / {{disk}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 5,
      "title": "SMART Errors Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_media_errors{instance=~\"$instance\"}",
          "legendFormat": "media / {{instance}} / {{disk}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_num_err_log_entries{instance=~\"$instance\"}",
          "legendFormat": "log / {{instance}} / {{disk}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "smartmon_critical_warning{instance=~\"$instance\"}",
          "legendFormat": "crit / {{instance}} / {{disk}}",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "id": 6,
      "title": "Data Read Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(smartmon_data_units_read{instance=~\"$instance\"}[5m]) * 512000",
          "legendFormat": "{{instance}} / {{disk}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "id": 7,
      "title": "Data Write Rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(smartmon_data_units_written{instance=~\"$instance\"}[5m]) * 512000",
          "legendFormat": "{{instance}} / {{disk}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {},
