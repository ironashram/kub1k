        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(veeam_backup_running{instance=~\"$instance\"})",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          },
