      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "veeam_backup_last_processed_bytes{instance=~\"$instance\"} and on (instance, job_name) topk by (instance) (1, veeam_backup_last_end_timestamp_seconds{instance=~\"$instance\"})",
          "legendFormat": "{{instance}} / {{job_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 9,
      "title": "Trends",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 10,
      "title": "Transferred Per Backup",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "veeam_backup_last_transferred_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} / {{job_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 11,
      "title": "Duration Per Backup",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "veeam_backup_last_duration_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} / {{job_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null  },
              { "color": "yellow", "value": 86400 },
              { "color": "red",    "value": 172800 }
            ]
          },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "id": 12,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "title": "Time Since Last Success (per job, sorted)",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "time() - veeam_backup_last_successful_timestamp_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} / {{job_name}}",
          "refId": "A",
          "instant": true,
          "format": "time_series"
        }
      ],
      "transformations": [
        {
          "id": "renameByRegex",
          "options": { "regex": ".*\\{instance=\"([^\"]+)\", job_name=\"([^\"]+)\".*", "renamePattern": "$1 / $2" }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Value", "desc": true }] }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 13,
      "title": "Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0":  { "text": "Failed",    "color": "red"    },
                      "1":  { "text": "Success",   "color": "green"  },
                      "2":  { "text": "Warning",   "color": "yellow" },
                      "3":  { "text": "Running",   "color": "blue"   },
                      "4":  { "text": "Cancelled", "color": "orange" },
                      "-1": { "text": "Unknown",   "color": "red"    }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Last End" },
            "properties": [{ "id": "unit", "value": "dateTimeAsIso" }]
          },
          {
            "matcher": { "id": "byName", "options": "Last Success" },
            "properties": [{ "id": "unit", "value": "dateTimeAsIso" }]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [{ "id": "unit", "value": "s" }]
          },
          {
            "matcher": { "id": "byName", "options": "Processed" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Transferred" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "id": 14,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Instance", "desc": false }]
      },
      "title": "Backup Jobs",
      "type": "table",
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "id", "mode": "outer" }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "instance 1",
                "job_name 1",
                "Value #Status",
                "Value #End",
                "Value #Success",
                "Value #Duration",
                "Value #Processed",
                "Value #Transferred"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {
              "instance 1":         "Instance",
              "job_name 1":         "Job",
              "Value #Status":      "Status",
              "Value #End":         "Last End",
              "Value #Success":     "Last Success",
              "Value #Duration":    "Duration",
              "Value #Processed":   "Processed",
              "Value #Transferred": "Transferred"
            },
            "indexByName": {
              "instance 1":         0,
              "job_name 1":         1,
              "Value #Status":      2,
              "Value #End":         3,
              "Value #Success":     4,
              "Value #Duration":    5,
              "Value #Processed":   6,
              "Value #Transferred": 7
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(veeam_backup_last_status{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"job_name\")",
          "refId": "Status",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(veeam_backup_last_end_timestamp_seconds{instance=~\"$instance\"} * 1000, \"id\", \":\", \"instance\", \"job_name\")",
          "refId": "End",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(veeam_backup_last_successful_timestamp_seconds{instance=~\"$instance\"} * 1000, \"id\", \":\", \"instance\", \"job_name\")",
          "refId": "Success",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(veeam_backup_last_duration_seconds{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"job_name\")",
          "refId": "Duration",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(veeam_backup_last_processed_bytes{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"job_name\")",
          "refId": "Processed",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "label_join(veeam_backup_last_transferred_bytes{instance=~\"$instance\"}, \"id\", \":\", \"instance\", \"job_name\")",
          "refId": "Transferred",
          "instant": true,
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(veeam_backup_last_status, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "multi": true,
        "name": "instance",
        "options": [],
        "query": {
          "query": "label_values(veeam_backup_last_status, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "title": "Veeam Backups",
  "uid": "veeam-backup",
  "version": 1
